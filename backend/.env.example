APP_NAME="AI Logopedic Speech Analysis Platform"
API_PREFIX="/api"
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/speech_ai"
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL_SECONDS=300
AUDIO_CACHE_TTL_SECONDS=3600
